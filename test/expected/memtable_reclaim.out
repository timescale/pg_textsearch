UPDATE multi_cycle_bounds SET max_live_pages = GREATEST(
    max_live_pages,
    (SELECT count(*)::int FROM bm25_memtable_chain('memtable_reclaim_idx')));
SELECT bm25_spill_index('memtable_reclaim_idx') IS NOT NULL AS mc_spill_3;
