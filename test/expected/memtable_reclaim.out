(1 row)

VACUUM ANALYZE memtable_reclaim_t;
-- Cycle 5
INSERT INTO memtable_reclaim_t (body)
SELECT 'mc5 doc ' || g || ' ' || repeat('pad ', 6)
FROM generate_series(1, 200) g;
UPDATE multi_cycle_bounds SET max_live_pages = GREATEST(
